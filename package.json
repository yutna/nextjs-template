{
  "name": "vibe-next-template",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "build": "next build --webpack",
    "build:analyze": "cross-env ANALYZE=true next build --webpack",
    "build:storybook": "storybook build",
    "check-types": "tsc --noEmit",
    "dev": "next dev --webpack",
    "dev:storybook": "storybook dev -p 6006 --no-open",
    "format": "prettier --write .",
    "lint": "run-s lint:eslint lint:css lint:check",
    "lint:check": "node --experimental-strip-types --no-warnings bin/vibe lint:check",
    "lint:css": "stylelint \"src/**/*.module.css\"",
    "lint:eslint": "eslint",
    "start": "next start",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ark-ui/react": "5.34.1",
    "@chakra-ui/react": "3.34.0",
    "@emotion/react": "11.14.0",
    "@t3-oss/env-nextjs": "0.13.10",
    "@xstate/react": "6.1.0",
    "@zag-js/react": "1.36.0",
    "clsx": "2.1.1",
    "dayjs": "1.11.20",
    "effect": "3.19.19",
    "immer": "11.1.4",
    "motion": "12.36.0",
    "next": "16.1.6",
    "next-intl": "4.8.3",
    "next-safe-action": "8.1.8",
    "next-themes": "0.4.6",
    "nuqs": "2.8.9",
    "pino": "10.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "5.6.0",
    "server-only": "0.0.1",
    "sharp": "0.34.5",
    "swr": "2.4.1",
    "ts-pattern": "5.9.0",
    "use-immer": "0.11.0",
    "usehooks-ts": "3.1.1",
    "xstate": "5.28.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.0.2",
    "@next/bundle-analyzer": "16.1.6",
    "@storybook/addon-a11y": "10.3.3",
    "@storybook/addon-docs": "10.3.3",
    "@storybook/nextjs-vite": "10.3.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.0",
    "agent-browser": "0.20.0",
    "babel-plugin-react-compiler": "1.0.0",
    "cross-env": "10.1.0",
    "eslint": "9.39.3",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-check-file": "3.3.1",
    "eslint-plugin-jsonc": "3.1.2",
    "eslint-plugin-perfectionist": "5.6.0",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-storybook": "10.2.19",
    "jsdom": "28.1.0",
    "node-addon-api": "8.6.0",
    "node-gyp": "12.2.0",
    "npm-run-all2": "8.0.4",
    "pino-pretty": "13.1.3",
