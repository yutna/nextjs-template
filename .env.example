# Public API endpoint (required)
NEXT_PUBLIC_API_URL=https://api.example.com

# Database URL defaults for the template DB scaffold (local libSQL/sqlite file mode)
DATABASE_URL=file:src/shared/db/local/development.sqlite
# Used by `npm run db:prepare:test` and local test DB flows
DATABASE_URL_TEST=file:src/shared/db/local/test.sqlite
# Local production fallback only; use a remote libSQL/Turso URL in real production
DATABASE_URL_PRODUCTION=file:src/shared/db/local/production.sqlite

# Test DB isolation strategy for src/shared/lib/db-isolation: noop | sqlite-file-reset
DB_TEST_ISOLATION_STRATEGY=noop
