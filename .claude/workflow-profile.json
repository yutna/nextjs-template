{
  "version": 1,
  "profileId": "nextjs-enterprise-claude",
  "repository": {
    "name": "vibe-next-template",
    "role": "application",
    "packageManager": "npm",
    "generatedIgnorePatterns": [
      ".claude/hooks/*.log",
      "coverage/",
      "dist/",
      "node_modules/",
      ".next/"
    ]
  },
  "stack": {
    "framework": "next@16",
    "react": "19",
    "ui": ["chakra-ui@3", "ark-ui"],
    "state": ["xstate", "zag-js", "nuqs", "immer"],
    "functional": "effect",
    "database": "drizzle",
    "jobs": "trigger.dev",
    "i18n": "next-intl",
    "serverActions": "next-safe-action",
    "validation": "zod",
    "logging": "pino",
    "testing": ["vitest", "testing-library", "@faker-js/faker"],
    "env": "@t3-oss/env-nextjs"
  },
  "locales": {
    "supported": ["en", "th"],
    "default": "en",
    "prefix": "always"
  },
  "commands": {
    "validateState": "node .claude/hooks/scripts/workflow_hook.cjs validate-state",
    "typecheck": "npm run check-types",
    "lint": "npm run lint",
    "tests": "npm run test",
    "coverage": "npm run test:coverage",
    "dbGenerate": "npm run db:generate",
    "dbMigrate": "npm run db:migrate",
    "dbSeed": "npm run db:seed",
    "indexCodebase": "node .claude/hooks/scripts/codebase_indexer.cjs"
  },
  "adoption": {
    "supportedModes": ["from-scratch", "adopt-existing-project"],
    "defaultTaskId": "bootstrap-workflow-adoption",
    "defaultTaskSummary": "Bootstrap workflow adoption and discovery for this repository.",
    "recommendedAppRoot": "src/app",
    "recommendedModuleRoot": "src/modules",
    "recommendedSharedRoot": "src/shared",
    "recommendedSourceRoots": ["src"],
    "recommendedModuleRoots": ["src/modules"],
    "recommendedTestRoots": ["src/__tests__", "tests"]
  },
  "roots": {
    "sourceRoots": ["src"],
    "moduleRoots": ["src/modules"],
    "testRoots": ["src/__tests__"]
  },
  "conventions": {
    "model": "contract-driven",
    "principle": "convention-over-deliberation",
    "hard": [
      "Respect the six-phase workflow and state contract.",
      "Preserve src/modules/<feature>/{actions,api,services,repositories,components,containers,screens,hooks,schemas,providers} structure.",
      "Preserve src/shared/{db,entities,services,lib,config,components,providers,schemas,styles} structure.",
      "Use quality-gate sequence before delivery.",
      "Preserve repository naming, route, and boundary grammar declared by the active profile.",
      "Entities (Drizzle schemas) live in shared/entities/ only, never in modules.",
      "Schemas (Zod) live in schemas/ folder, not in lib/.",
      "Global styles live in shared/styles/ only; modules use CSS modules if needed.",
      "No cross-module imports; if module A needs something from module B, move it to shared.",
      "No relative imports beyond current folder; use ./ for same folder, @/ alias for everything else.",
      "No barrel re-exports from grouping folders (e.g., no components/index.ts that re-exports all)."
    ],
    "strong": [
      "Heavy server-side approach: minimize client logic, maximize server-side processing.",
      "Server-first components (RSC by default).",
      "Chakra UI v3 for UI components.",
      "XState for complex state machines, Zag.js for UI primitives.",
      "next-safe-action + Zod for server actions.",
      "Effect ALWAYS for backend layers (services, repositories, jobs, api handlers).",
      "Drizzle for database access, always through repositories.",
      "Trigger.dev for background jobs.",
      "Pino for structured logging.",
      "@t3-oss/env-nextjs for environment validation.",
      "actions/ for internal mutations (from Next.js UI); api/ for external consumers (webhooks, mobile, third-party).",
      "lib/ for domain implementations and wrappers (e.g., Stripe API); utils/ for pure utility functions (e.g., format-thai-currency).",
      "Reuse the repository module shapes, adoption defaults, and approved libraries before inventing new patterns.",
      "Prefer the smallest boundary change and the narrowest side-effect surface that solves the task.",
      "Prefer extending the existing repository grammar over reorganizing it."
    ],
    "local": [
      "Helper extraction within modules.",
      "Internal function decomposition.",
      "Component file organization within containers/components.",
      "Private helper extraction inside an approved boundary.",
      "Implementation detail that stays inside the approved plan and validation path."
    ]
  },
  "structure": {
    "forbiddenGenericFiles": [
      "utils.ts",
      "utils.tsx",
      "common.ts",
      "common.tsx"
    ],
    "moduleSubdirs": [
      "actions",
      "api",
      "components",
      "constants",
      "containers",
      "contexts",
      "forms",
      "hooks",
      "jobs",
      "layouts",
      "lib",
      "policies",
      "presenters",
      "providers",
      "repositories",
      "schemas",
      "screens",
      "services",
      "types",
      "utils"
    ],
    "sharedSubdirs": [
      "actions",
      "api",
      "components",
      "config",
      "constants",
      "contexts",
      "db",
      "entities",
      "factories",
      "hooks",
      "images",
      "jobs",
      "layouts",
      "lib",
      "middleware",
      "policies",
      "presenters",
      "providers",
      "queue",
      "routes",
      "schemas",
      "seeds",
      "services",
      "styles",
      "types",
      "utils",
      "vendor"
    ],
    "alwaysFolders": [
      "actions",
      "api",
      "components",
      "containers",
      "contexts",
      "entities",
      "forms",
      "hooks",
      "jobs",
      "layouts",
      "lib",
      "middleware",
      "policies",
      "presenters",
      "providers",
      "repositories",
      "schemas",
      "services",
      "utils"
    ],
    "alwaysFlatFiles": ["config", "constants", "images", "styles", "types"],
    "infrastructureFolders": ["db", "queue"],
    "sharedOnlyFolders": [
      "db",
      "entities",
      "middleware",
      "queue",
      "seeds",
      "factories"
    ],
    "specialFolders": ["routes"],
    "namingPatterns": {
      "components": "<semantic-type>-<name>",
      "containers": "container-<name>",
      "screens": "screen-<name>",
      "hooks": "use-<name>",
      "actions": "<name>-action",
      "apiHandlers": "<name>-handler",
      "services": "<name>-service",
      "repositories": "<name>-repository",
      "jobs": "<name>-job",
      "policies": "<name>-policy",
      "entities": "<name>",
      "forms": "<name>-form",
      "presenters": "<name>-presenter"
    },
    "componentSemanticTypes": [
      "form",
      "modal",
      "alert",
      "section",
      "menu",
      "card",
      "table",
      "list",
      "button",
      "input",
      "dialog",
      "drawer",
      "toast",
      "badge",
      "avatar",
      "icon"
    ],
    "requiredFiles": {
      "inFolders": ["index.ts", "*.test.ts(x)"],
      "componentsOnly": ["*.stories.tsx"],
      "noTestsRequired": ["entities"],
      "conditionalFiles": {
        "types.ts": "if types or props exist",
        "constants.ts": "if constants exist",
        "helpers.ts": "if helper functions exist (internal only, not exported)",
        "relations.ts": "for entities with Drizzle relations"
      }
    },
    "importRules": {
      "sameFolderRelative": "./",
      "crossFolderAlias": "@/",
      "forbiddenPatterns": ["../", "../../"],
      "noBarrelReexports": "grouping folders (e.g., components/) must not have index.ts that re-exports all"
    }
  },
  "patternGraph": {
    "nodes": {
      "entity": {
        "location": "shared/entities/<name>/",
        "files": [
          "<name>.ts",
          "types.ts",
          "relations.ts",
          "hooks.ts",
          "scopes.ts"
        ],
        "depends": [],
        "description": "Drizzle schema definition"
      },
      "entity-hooks": {
        "location": "shared/entities/<name>/hooks.ts",
        "depends": ["entity"],
        "description": "Lifecycle callbacks (beforeCreate, afterCreate, etc.)"
      },
      "query-scopes": {
        "location": "shared/entities/<name>/scopes.ts",
        "depends": ["entity"],
        "description": "Reusable WHERE conditions"
      },
      "repository": {
        "location": "modules/<module>/repositories/<name>-repository/",
        "depends": ["entity"],
        "mayUse": ["entity-hooks", "query-scopes"],
        "description": "Data access layer (CRUD operations)"
      },
      "service": {
        "location": "modules/<module>/services/<name>-service/",
        "depends": ["repository"],
        "mayUse": ["policy", "entity-hooks"],
        "mayTrigger": ["job", "email-service", "realtime-service"],
        "description": "Business logic and orchestration"
      },
      "policy": {
        "location": "modules/<module>/policies/<name>-policy/",
        "depends": ["entity"],
        "description": "Authorization rules"
      },
      "action": {
        "location": "modules/<module>/actions/<name>-action/",
        "depends": ["service"],
        "mayUse": ["zod-schema"],
        "description": "Server action for UI mutations"
      },
      "api-handler": {
        "location": "modules/<module>/api/<name>-handler/",
        "depends": ["service"],
        "mayUse": ["presenter"],
        "description": "API route for external consumers"
      },
      "presenter": {
        "location": "modules/<module>/presenters/<name>-presenter/",
        "depends": ["entity"],
        "description": "Entity to JSON transformation"
      },
      "form-object": {
        "location": "modules/<module>/forms/<name>-form/",
        "depends": ["zod-schema"],
        "produces": ["entity"],
        "description": "Complex form validation and transformation"
      },
      "zod-schema": {
        "location": "modules/<module>/schemas/<name>-schema/",
        "depends": [],
        "description": "Input validation schema"
      },
      "job": {
        "location": "modules/<module>/jobs/<name>-job/",
        "depends": ["service"],
        "description": "Background task (Trigger.dev)"
      },
      "email-service": {
        "location": "shared/services/email/",
        "depends": [],
        "description": "Transactional email sending"
      },
      "realtime-service": {
        "location": "shared/services/realtime/",
        "depends": [],
        "description": "Real-time communication (SSE/Pusher)"
      },
      "screen": {
        "location": "modules/<module>/screens/screen-<name>/",
        "depends": ["service"],
        "mayUse": ["container", "component"],
        "description": "Page-level composition (server)"
      },
      "container": {
        "location": "modules/<module>/containers/container-<name>/",
        "depends": ["action", "hook"],
        "mayUse": ["component"],
        "description": "Client-side data binding"
      },
      "component": {
        "location": "modules/<module>/components/<type>-<name>/",
        "depends": [],
        "description": "Pure UI component (server)"
      },
      "hook": {
        "location": "modules/<module>/hooks/use-<name>/",
        "depends": [],
        "description": "Custom React hook (client)"
      },
      "factory": {
        "location": "shared/factories/<name>-factory/",
        "depends": ["entity"],
        "description": "Test data factory"
      }
    },
    "edges": [
      { "from": "action", "to": "service", "type": "calls" },
      { "from": "api-handler", "to": "service", "type": "calls" },
      { "from": "api-handler", "to": "presenter", "type": "uses" },
      { "from": "service", "to": "repository", "type": "calls" },
      { "from": "service", "to": "policy", "type": "checks" },
      { "from": "service", "to": "job", "type": "triggers" },
      { "from": "service", "to": "email-service", "type": "triggers" },
      { "from": "service", "to": "realtime-service", "type": "triggers" },
      { "from": "repository", "to": "entity", "type": "queries" },
      { "from": "repository", "to": "entity-hooks", "type": "invokes" },
      { "from": "repository", "to": "query-scopes", "type": "uses" },
      { "from": "presenter", "to": "entity", "type": "transforms" },
      { "from": "form-object", "to": "zod-schema", "type": "uses" },
      { "from": "form-object", "to": "entity", "type": "produces" },
      { "from": "policy", "to": "entity", "type": "authorizes" },
      { "from": "screen", "to": "service", "type": "fetches" },
      { "from": "screen", "to": "container", "type": "renders" },
      { "from": "container", "to": "action", "type": "calls" },
      { "from": "container", "to": "hook", "type": "uses" },
      { "from": "container", "to": "component", "type": "renders" },
      { "from": "factory", "to": "entity", "type": "creates" }
    ],
    "workflows": {
      "crud-feature": {
        "description": "Basic CRUD operations for an entity",
        "patterns": [
          "entity",
          "repository",
          "service",
          "action",
          "presenter",
          "screen"
        ],
        "optional": ["policy", "query-scopes", "entity-hooks"]
      },
      "user-registration": {
        "description": "User signup with email verification",
        "patterns": [
          "entity",
          "form-object",
          "service",
          "repository",
          "action"
        ],
        "optional": ["entity-hooks", "email-service", "job"]
      },
      "api-endpoint": {
        "description": "External API for third-party consumers",
        "patterns": ["api-handler", "service", "repository", "presenter"],
        "optional": ["policy"]
      },
      "background-task": {
        "description": "Long-running or scheduled task",
        "patterns": ["job", "service", "repository"],
        "optional": ["email-service", "realtime-service"]
      },
      "real-time-feature": {
        "description": "Live updates to clients",
        "patterns": ["realtime-service", "service"],
        "optional": ["job"]
      }
    }
  }
}
