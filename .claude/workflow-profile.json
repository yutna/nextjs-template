{
  "version": 1,
  "profileId": "nextjs-enterprise-claude",
  "repository": {
    "name": "vibe-next-template",
    "role": "application",
    "packageManager": "npm",
    "generatedIgnorePatterns": [
      ".claude/hooks/*.log",
      "coverage/",
      "dist/",
      "node_modules/",
      ".next/"
    ]
  },
  "stack": {
    "framework": "next@16",
    "react": "19",
    "ui": ["chakra-ui@3", "ark-ui"],
    "state": ["xstate", "zag-js", "nuqs", "immer"],
    "functional": "effect",
    "i18n": "next-intl",
    "serverActions": "next-safe-action",
    "validation": "zod",
    "logging": "pino",
    "testing": ["vitest", "testing-library"],
    "env": "@t3-oss/env-nextjs"
  },
  "locales": {
    "supported": ["en", "th"],
    "default": "en",
    "prefix": "always"
  },
  "commands": {
    "validateState": "node .claude/hooks/scripts/workflow_hook.cjs validate-state",
    "typecheck": "npm run check-types",
    "lint": "npm run lint",
    "tests": "npm run test",
    "coverage": "npm run test:coverage"
  },
  "adoption": {
    "supportedModes": ["from-scratch", "adopt-existing-project"],
    "defaultTaskId": "bootstrap-workflow-adoption",
    "defaultTaskSummary": "Bootstrap workflow adoption and discovery for this repository.",
    "recommendedAppRoot": "src/app",
    "recommendedModuleRoot": "src/modules",
    "recommendedSharedRoot": "src/shared",
    "recommendedSourceRoots": ["src"],
    "recommendedModuleRoots": ["src/modules"],
    "recommendedTestRoots": ["src/__tests__", "tests"]
  },
  "roots": {
    "sourceRoots": ["src"],
    "moduleRoots": ["src/modules"],
    "testRoots": ["src/__tests__"]
  },
  "conventions": {
    "model": "contract-driven",
    "principle": "convention-over-deliberation",
    "hard": [
      "Respect the six-phase workflow and state contract.",
      "Preserve src/modules/<feature>/{actions,components,containers,screens,hooks,schemas,providers} structure.",
      "Preserve src/shared/{lib,config,components,providers,schemas,styles} structure.",
      "Use quality-gate sequence before delivery.",
      "Preserve repository naming, route, and boundary grammar declared by the active profile.",
      "Schemas live in schemas/ folder, not in lib/.",
      "Global styles live in shared/styles/ only; modules use CSS modules if needed."
    ],
    "strong": [
      "Server-first components (RSC by default).",
      "Chakra UI v3 for UI components.",
      "XState for complex state machines, Zag.js for UI primitives.",
      "next-safe-action + Zod for server actions.",
      "Effect for composable, type-safe error handling and complex async flows.",
      "Pino for structured logging.",
      "@t3-oss/env-nextjs for environment validation.",
      "lib/ for domain implementations and wrappers (e.g., Stripe API); utils/ for pure utility functions (e.g., format-thai-currency).",
      "Reuse the repository module shapes, adoption defaults, and approved libraries before inventing new patterns.",
      "Prefer the smallest boundary change and the narrowest side-effect surface that solves the task.",
      "Prefer extending the existing repository grammar over reorganizing it."
    ],
    "local": [
      "Helper extraction within modules.",
      "Internal function decomposition.",
      "Component file organization within containers/components.",
      "Private helper extraction inside an approved boundary.",
      "Implementation detail that stays inside the approved plan and validation path."
    ]
  },
  "structure": {
    "forbiddenGenericFiles": ["utils.ts", "utils.tsx", "helpers.ts", "helpers.tsx", "common.ts", "common.tsx"],
    "moduleSubdirs": ["actions", "components", "constants", "containers", "contexts", "hooks", "layouts", "lib", "providers", "schemas", "screens", "types", "utils"],
    "sharedSubdirs": ["actions", "api", "components", "config", "constants", "contexts", "hooks", "images", "layouts", "lib", "providers", "routes", "schemas", "styles", "types", "utils", "vendor"],
    "alwaysFolders": ["actions", "api", "components", "containers", "contexts", "hooks", "layouts", "lib", "providers", "schemas", "utils"],
    "alwaysFlatFiles": ["config", "constants", "images", "styles", "types"],
    "specialFolders": ["routes"],
    "namingPatterns": {
      "components": "<semantic-type>-<name>",
      "containers": "container-<name>",
      "screens": "screen-<name>",
      "hooks": "use-<name>",
      "actions": "<name>-action"
    },
    "componentSemanticTypes": ["form", "modal", "alert", "section", "menu", "card", "table", "list", "button", "input", "dialog", "drawer", "toast", "badge", "avatar", "icon"],
    "requiredFiles": {
      "inFolders": ["index.ts", "*.test.ts(x)"],
      "componentsOnly": ["*.stories.tsx"],
      "conditionalFiles": {
        "types.ts": "if types or props exist",
        "constants.ts": "if constants exist",
        "helpers.ts": "if helper functions exist (internal only, not exported)"
      }
    }
  }
}
